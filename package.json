{
  "name": "convrtd-brandify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Turn any Word/PDF document into an on-brand CONVRTD PDF.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "make-samples": "tsx scripts/make-samples.ts",
    "batch": "tsx scripts/run-batch.ts",
    "rasterize": "python scripts/rasterize.py"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@aws-sdk/client-s3": "^3.1087.0",
    "@aws-sdk/s3-request-presigner": "^3.1087.0",
    "@fastify/multipart": "^9.2.1",
    "@fastify/static": "^8.2.0",
    "docx": "^9.5.1",
    "fastify": "^5.6.1",
    "mammoth": "^1.11.0",
    "node-html-parser": "^7.1.0",
    "pdfjs-dist": "^4.10.38",
    "playwright": "^1.56.0",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
