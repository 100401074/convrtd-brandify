# --- Server ---
PORT=5178

# --- Optional: Claude structuring upgrade ---
# The app works fully without it (a deterministic heuristic structurer is the default).
ANTHROPIC_API_KEY=
STRUCTURE_MODEL=claude-opus-4-8

# --- Optional: Cloudflare R2 (host generated PDFs, return a download link) ---
# When these are set, generated PDFs are uploaded to R2 and the UI shows a download
# link. When unset, the PDF is served straight from the app instead.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=convrtd-brandify
# Set a public base URL for a public bucket / custom domain (e.g. https://files.convrtd.co).
# Leave blank to serve time-limited presigned links instead.
R2_PUBLIC_BASE=
R2_URL_TTL_DAYS=7
